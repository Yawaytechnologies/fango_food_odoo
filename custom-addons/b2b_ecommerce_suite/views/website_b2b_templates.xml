    <template id="b2b_home_page" name="B2B Commerce Home">
        <t t-call="website.layout">
            <div class="b2b-page py-4 py-md-5">
                <div class="container">
                    <section class="b2b-hero mb-4 mb-md-5">
                        <div class="row align-items-center">
                            <div class="col-lg-7">
                                <span class="badge rounded-pill bg-light text-dark mb-3">B2B Commerce Portal</span>
                                <h1 class="b2b-title display-5 mb-3">Wholesale Ordering, Credit Terms, and Account Approval in One Flow</h1>
                                <p class="lead mb-4">Build company accounts, offer contract pricing, and let buyers self-serve from catalog to invoice while admin keeps full approval control.</p>
                                <div class="d-flex flex-wrap gap-2">
                                    <a class="b2b-btn b2b-btn-primary" href="/b2b/register">Request Business Account</a>
                                    <a class="b2b-btn b2b-btn-secondary" href="/shop">Browse Catalog</a>
                                </div>
                            </div>
                            <div class="col-lg-5 mt-4 mt-lg-0">
                                <div class="b2b-kpi mb-3">
                                    <h5 class="mb-1">Buyer Experience</h5>
                                    <p class="mb-0 text-muted">Fast reorder, negotiated pricing, and role-based account access.</p>
                                </div>
                                <div class="b2b-kpi mb-3">
                                    <h5 class="mb-1">Operations</h5>
                                    <p class="mb-0 text-muted">Inventory sync, quotation-to-order pipeline, and invoice tracking.</p>
                                </div>
                                <div class="b2b-kpi">
                                    <h5 class="mb-1">Finance</h5>
                                    <p class="mb-0 text-muted">Credit limits, payment terms, receivables visibility.</p>
                                </div>
                            </div>
                        </div>
                    </section>

                    <section class="mb-4 mb-md-5">
                        <div class="d-flex align-items-center justify-content-between mb-3">
                            <h2 class="h3 mb-0">Single Business Flow</h2>
                        </div>
                        <div class="row g-3">
                            <div class="col-md-6 col-lg-3">
                                <div class="b2b-flow-card">
                                    <div class="b2b-flow-step">1</div>
                                    <h5>Company Registration</h5>
                                    <p class="mb-0 text-muted">Buyer submits business details on the B2B signup form.</p>
                                </div>
                            </div>
                            <div class="col-md-6 col-lg-3">
                                <div class="b2b-flow-card">
                                    <div class="b2b-flow-step">2</div>
                                    <h5>Admin Approval</h5>
                                    <p class="mb-0 text-muted">Admin validates request, assigns terms, and activates the portal account.</p>
                                </div>
                            </div>
                            <div class="col-md-6 col-lg-3">
                                <div class="b2b-flow-card">
                                    <div class="b2b-flow-step">3</div>
                                    <h5>Order &amp; Fulfill</h5>
                                    <p class="mb-0 text-muted">User places bulk orders; stock and delivery operations run in Inventory.</p>
                                </div>
                            </div>
                            <div class="col-md-6 col-lg-3">
                                <div class="b2b-flow-card">
                                    <div class="b2b-flow-step">4</div>
                                    <h5>Invoice &amp; Collect</h5>
                                    <p class="mb-0 text-muted">Accounting issues invoices and tracks payment against terms.</p>
                                </div>
                            </div>
                        </div>
                    </section>

                    <section class="b2b-panel p-4 p-md-5">
                        <div class="row align-items-center">
                            <div class="col-lg-8">
                                <h2 class="h3 mb-2">Start With the Right Entry Point</h2>
                                <p class="text-muted mb-0">Use registration for new companies, login for approved buyers, and catalog for direct product discovery.</p>
                            </div>
                            <div class="col-lg-4 mt-3 mt-lg-0 text-lg-end">
                                <a class="b2b-btn b2b-btn-primary me-2" href="/b2b/login">B2B Login</a>
                                <a class="b2b-btn b2b-btn-secondary text-dark border-0" style="background:#f7f3eb" href="/b2b/register">Signup</a>
                            </div>
                        </div>
                    </section>
                </div>
            </div>
        </t>
    </template>

