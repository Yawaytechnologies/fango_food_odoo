<odoo>
    <record id="view_b2b_signup_request_tree" model="ir.ui.view">
        <field name="name">b2b.signup.request.tree</field>
        <field name="model">b2b.signup.request</field>
        <field name="arch" type="xml">
            <tree string="B2B Signup Requests">
                <field name="name"/>
                <field name="company_name"/>
                <field name="contact_name"/>
                <field name="email"/>
                <field name="business_type"/>
                <field name="state"/>
                <field name="create_date"/>
            </tree>
        </field>
    </record>

    <record id="view_b2b_signup_request_form" model="ir.ui.view">
        <field name="name">b2b.signup.request.form</field>
        <field name="model">b2b.signup.request</field>
        <field name="arch" type="xml">
            <form string="B2B Signup Request">
                <header>
                    <button name="action_submit" string="Submit" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_approve" string="Approve &amp; Create Account" type="object" class="btn-primary" invisible="state not in ['submitted', 'draft']"/>
                    <button name="action_reject" string="Reject" type="object" class="btn-secondary" invisible="state in ['approved', 'rejected']"/>
                    <button name="action_reset_to_draft" string="Reset to Draft" type="object" invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,approved,rejected"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="company_name"/>
                            <field name="contact_name"/>
                            <field name="email"/>
                            <field name="phone"/>
                            <field name="website"/>
                        </group>
                        <group>
                            <field name="business_type"/>
                            <field name="monthly_order_value"/>
                            <field name="pricelist_id" options="{'no_create': True}"/>
                            <field name="payment_term_id" options="{'no_create': True}"/>
                            <field name="gst_vat"/>
                            <field name="approved_by" readonly="1"/>
                            <field name="approved_date" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Address">
                            <group>
                                <field name="street"/>
                                <field name="street2"/>
                                <field name="city"/>
                                <field name="state_id"/>
                                <field name="zip"/>
                                <field name="country_id"/>
                            </group>
                        </page>
                        <page string="Details">
                            <group>
                                <field name="notes"/>
                                <field name="user_note" readonly="1"/>
                                <field name="rejection_reason" readonly="state != 'rejected'"/>
                            </group>
                        </page>
                        <page string="Created Records">
                            <group>
                                <field name="partner_id" readonly="1"/>
                                <field name="user_id" readonly="1"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_b2b_signup_request_search" model="ir.ui.view">
        <field name="name">b2b.signup.request.search</field>
        <field name="model">b2b.signup.request</field>
        <field name="arch" type="xml">
            <search string="B2B Signup Requests">
                <field name="name"/>
                <field name="company_name"/>
                <field name="email"/>
                <filter string="Submitted" name="submitted" domain="[('state', '=', 'submitted')]"/>
                <filter string="Approved" name="approved" domain="[('state', '=', 'approved')]"/>
                <filter string="Rejected" name="rejected" domain="[('state', '=', 'rejected')]"/>
                <group expand="0" string="Group By">
                    <filter string="State" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Business Type" name="group_type" context="{'group_by': 'business_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_b2b_signup_requests" model="ir.actions.act_window">
        <field name="name">Signup Requests</field>
        <field name="res_model">b2b.signup.request</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_b2b_signup_request_search"/>
    </record>
</odoo>
