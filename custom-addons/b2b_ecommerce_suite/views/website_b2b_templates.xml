    <template id="b2b_login_page" name="B2B Login Page">
        <t t-call="website.layout">
            <div class="b2b-page py-5">
                <div class="container">
                    <div class="b2b-login-wrap">
                        <div class="b2b-panel p-4 p-md-5">
                            <div class="text-center mb-4">
                                <h3 class="b2b-title mb-2">B2B Sign In</h3>
                                <p class="text-muted mb-0">Use your approved account credentials and continue to your business dashboard.</p>
                            </div>
                            <t t-if="values.get('error')">
                                <div class="alert alert-danger" role="alert">
                                    <t t-esc="values.get('error')"/>
                                </div>
                            </t>
                            <form action="/web/login" method="post" class="b2b-login-form">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                <input type="hidden" name="redirect" t-att-value="values.get('redirect', '/my')"/>
                                <div class="mb-3">
                                    <label class="form-label">Email</label>
                                    <input type="text" name="login" class="form-control" t-att-value="values.get('login', '')" required="required" autocomplete="username"/>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Password</label>
                                    <input type="password" name="password" class="form-control" required="required" autocomplete="current-password"/>
                                </div>
                                <button class="b2b-btn b2b-btn-primary w-100 text-center border-0" type="submit">Sign In</button>
                            </form>
                            <div class="text-center mt-3">
                                <a class="btn btn-link" href="/web/reset_password">Forgot password?</a>
                            </div>
                            <div class="text-center">
                                <a class="btn btn-link" href="/b2b/register">Need business approval? Register</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>
</odoo>
