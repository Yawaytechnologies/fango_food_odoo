    <template id="b2b_register_page" name="B2B Register Page">
        <t t-call="website.layout">
            <div class="b2b-page py-5">
                <div class="container">
                    <div class="row justify-content-center">
                        <div class="col-lg-9">
                            <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
                                <div>
                                    <h1 class="b2b-title h2 mb-1">Create B2B Account Request</h1>
                                    <p class="text-muted mb-0">Admin verifies each company before account activation.</p>
                                </div>
                                <a href="/b2b/login" class="btn btn-outline-dark">Already approved? Sign in</a>
                            </div>

                            <t t-if="error">
                                <div class="alert alert-danger" role="alert">
                                    <t t-esc="error"/>
                                </div>
                            </t>

                            <form action="/b2b/register/submit" method="post" class="b2b-panel p-4 b2b-register">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label class="form-label">Company Name *</label>
                                        <input type="text" class="form-control" name="company_name" t-att-value="values.get('company_name', '')" required="required"/>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Contact Name *</label>
                                        <input type="text" class="form-control" name="contact_name" t-att-value="values.get('contact_name', '')" required="required"/>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Email *</label>
                                        <input type="email" class="form-control" name="email" t-att-value="values.get('email', '')" required="required"/>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Phone</label>
                                        <input type="text" class="form-control" name="phone" t-att-value="values.get('phone', '')"/>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Website</label>
                                        <input type="url" class="form-control" name="website" t-att-value="values.get('website', '')"/>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">GST/VAT</label>
                                        <input type="text" class="form-control" name="gst_vat" t-att-value="values.get('gst_vat', '')"/>
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label">Business Type</label>
                                        <select name="business_type" class="form-select">
                                            <option value="distributor" t-att-selected="values.get('business_type') == 'distributor'">Distributor</option>
                                            <option value="retailer" t-att-selected="not values.get('business_type') or values.get('business_type') == 'retailer'">Retailer</option>
                                            <option value="wholesaler" t-att-selected="values.get('business_type') == 'wholesaler'">Wholesaler</option>
                                            <option value="restaurant" t-att-selected="values.get('business_type') == 'restaurant'">Restaurant</option>
                                            <option value="other" t-att-selected="values.get('business_type') == 'other'">Other</option>
                                        </select>
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label">Expected Monthly Order Value</label>
                                        <input type="number" class="form-control" name="monthly_order_value" min="0" step="0.01" t-att-value="values.get('monthly_order_value', '')"/>
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label">Requested Pricelist</label>
                                        <select name="pricelist_id" class="form-select">
                                            <option value="">Select Pricelist</option>
                                            <t t-foreach="pricelists" t-as="pricelist">
                                                <option t-att-value="pricelist.id" t-att-selected="values.get('pricelist_id') and int(values.get('pricelist_id')) == pricelist.id"><t t-esc="pricelist.name"/></option>
                                            </t>
                                        </select>
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label">Country</label>
                                        <select name="country_id" class="form-select">
                                            <option value="">Select Country</option>
                                            <t t-foreach="countries" t-as="country">
                                                <option t-att-value="country.id" t-att-selected="values.get('country_id') and int(values.get('country_id')) == country.id"><t t-esc="country.name"/></option>
                                            </t>
                                        </select>
                                    </div>
                                    <div class="col-md-8">
                                        <label class="form-label">Street</label>
                                        <input type="text" class="form-control" name="street" t-att-value="values.get('street', '')"/>
                                    </div>
                                    <div class="col-md-12">
                                        <label class="form-label">Street 2</label>
                                        <input type="text" class="form-control" name="street2" t-att-value="values.get('street2', '')"/>
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label">City</label>
                                        <input type="text" class="form-control" name="city" t-att-value="values.get('city', '')"/>
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label">State</label>
                                        <select name="state_id" class="form-select">
                                            <option value="">Select State</option>
                                            <t t-foreach="states" t-as="state">
                                                <option t-att-value="state.id" t-att-selected="values.get('state_id') and int(values.get('state_id')) == state.id"><t t-esc="state.display_name"/></option>
                                            </t>
                                        </select>
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label">ZIP</label>
                                        <input type="text" class="form-control" name="zip" t-att-value="values.get('zip', '')"/>
                                    </div>
                                    <div class="col-md-12">
                                        <label class="form-label">Notes</label>
                                        <textarea class="form-control" name="notes" rows="4"><t t-esc="values.get('notes', '')"/></textarea>
                                    </div>
                                    <div class="col-md-12 d-flex justify-content-end mt-2">
                                        <button class="btn btn-dark px-4" type="submit">Submit Request</button>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

